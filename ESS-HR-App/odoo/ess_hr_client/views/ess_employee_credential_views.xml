<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Inline view for employee form tab ─────────────────────────────────── -->
    <record id="view_ess_employee_credential_inline" model="ir.ui.view">
        <field name="name">ess.employee.credential.inline</field>
        <field name="model">ess.employee.credential</field>
        <field name="arch" type="xml">
            <form string="Mobile Credentials">
                <header>
                    <button
                        name="action_reset_credentials"
                        string="Reset All Credentials"
                        type="object"
                        class="btn-warning"
                        confirm="This clears the PIN and password. The employee must set new credentials on next login. Continue?"
                        groups="base.group_system"/>
                </header>
                <sheet>
                    <group string="Mobile Identity">
                        <group>
                            <field name="username"
                                   placeholder="e.g. john.doe"
                                   help="Username for mobile app login. Falls back to work email if not set."/>
                            <field name="badge_id"
                                   placeholder="e.g. EMP-001"
                                   help="Badge ID for badge+PIN login. Must be unique within the company."/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="last_reset_date" readonly="1"/>
                            <field name="reset_by_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="PIN Credential">
                        <group>
                            <field name="pin_is_set" string="PIN Set" readonly="1" widget="boolean"/>
                            <field name="new_pin"
                                   password="True"
                                   placeholder="Min 4 digits — leave blank to keep current"/>
                        </group>
                    </group>
                    <group string="Password Credential">
                        <group>
                            <field name="password_is_set" string="Password Set" readonly="1" widget="boolean"/>
                            <field name="new_password"
                                   password="True"
                                   placeholder="Min 6 characters — leave blank to keep current"
                                   groups="base.group_system"/>
                        </group>
                    </group>
                    <group string="Stored Hashes" groups="base.group_system">
                        <field name="pin_hash" readonly="1"/>
                        <field name="password_hash" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Employee form extension — adds ESS Mobile tab ─────────────────────── -->
    <record id="view_hr_employee_ess_credentials_tab" model="ir.ui.view">
        <field name="name">hr.employee.ess.credentials</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="ESS Mobile" name="ess_mobile">
                    <field name="mobile_pin" invisible="1"/>
                    <field name="ess_credential_ids" nolabel="1"
                           context="{'default_employee_id': id}">
                        <list string="Mobile Credentials" editable="bottom">
                            <field name="username" placeholder="e.g. john.doe"/>
                            <field name="badge_id" placeholder="e.g. EMP-001"/>
                            <field name="pin_is_set" string="PIN Set" widget="boolean" readonly="1"/>
                            <field name="password_is_set" string="Password Set" widget="boolean" readonly="1"/>
                            <field name="active" widget="boolean_toggle"/>
                        </list>
                        <form string="Mobile Credentials">
                            <sheet>
                                <group string="Mobile Identity">
                                    <group>
                                        <field name="username" placeholder="e.g. john.doe"/>
                                        <field name="badge_id" placeholder="e.g. EMP-001"/>
                                        <field name="active"/>
                                    </group>
                                    <group>
                                        <field name="last_reset_date" readonly="1"/>
                                        <field name="reset_by_id" readonly="1"/>
                                    </group>
                                </group>
                                <group string="PIN">
                                    <field name="pin_is_set" string="PIN Set" readonly="1" widget="boolean"/>
                                    <field name="new_pin" password="True"
                                           placeholder="Min 4 digits — leave blank to keep current"/>
                                </group>
                                <group string="Password">
                                    <field name="password_is_set" string="Password Set" readonly="1" widget="boolean"/>
                                    <field name="new_password" password="True"
                                           placeholder="Min 6 characters — leave blank to keep current"/>
                                </group>
                                <footer>
                                    <button name="action_reset_credentials" string="Reset Credentials"
                                            type="object" class="btn-warning"/>
                                </footer>
                            </sheet>
                        </form>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- ── List + action (admin reference, not in main menu) ─────────────────── -->
    <record id="view_ess_employee_credential_list" model="ir.ui.view">
        <field name="name">ess.employee.credential.list</field>
        <field name="model">ess.employee.credential</field>
        <field name="arch" type="xml">
            <list string="Employee Mobile Credentials">
                <field name="employee_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="username"/>
                <field name="badge_id"/>
                <field name="pin_is_set" string="PIN" widget="boolean"/>
                <field name="password_is_set" string="Password" widget="boolean"/>
                <field name="last_reset_date"/>
                <field name="reset_by_id"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_ess_employee_credential" model="ir.actions.act_window">
        <field name="name">Employee Mobile Credentials</field>
        <field name="res_model">ess.employee.credential</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

</odoo>
