<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_ess_client" model="ir.ui.view">
        <field name="name">res.config.settings.view.ess.client</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="ESS Client" string="ESS Client" name="ess_hr_client">
                    <block title="Admin Server Connection" name="ess_admin_connection_block">
                        <setting string="Admin Connection Key" help="Secret key shared with the ESS Admin server. Must match the Connection Key on the server record in ESS Admin → Client Servers.">
                            <field name="ess_admin_connection_key" widget="password"
                                   placeholder="Paste key from ESS Admin → Client Servers → Generate Key"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

</odoo>
