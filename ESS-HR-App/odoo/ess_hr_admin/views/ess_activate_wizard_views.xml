<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ess_activate_servers_wizard_form" model="ir.ui.view">
        <field name="name">ess.activate.servers.wizard.form</field>
        <field name="model">ess.activate.servers.wizard</field>
        <field name="arch" type="xml">
            <form string="Activate Servers">
                <sheet>
                    <group>
                        <field name="license_id" readonly="1"/>
                    </group>
                    <group string="Deactivated Servers">
                        <field name="server_ids" nolabel="1" widget="many2many_checkboxes"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_activate"
                            string="Activate Selected"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
