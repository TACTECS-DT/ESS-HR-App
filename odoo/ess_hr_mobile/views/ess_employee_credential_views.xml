<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List view ───────────────────────────────────────────────────────── -->
    <record id="view_ess_employee_credential_list" model="ir.ui.view">
        <field name="name">ess.employee.credential.list</field>
        <field name="model">ess.employee.credential</field>
        <field name="arch" type="xml">
            <list string="Employee Mobile Credentials">
                <field name="employee_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="username"/>
                <field name="badge_id"/>

                <field name="pin_is_set" string="PIN" widget="boolean"/>
                <field name="password_is_set" string="Password" widget="boolean"/>
                <field name="last_reset_date"/>
                <field name="reset_by_id"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ── Form view ───────────────────────────────────────────────────────── -->
    <record id="view_ess_employee_credential_form" model="ir.ui.view">
        <field name="name">ess.employee.credential.form</field>
        <field name="model">ess.employee.credential</field>
        <field name="arch" type="xml">
            <form string="Employee Mobile Credentials">
                <header>
                    <button
                        name="action_reset_credentials"
                        string="Reset All Credentials"
                        type="object"
                        class="btn-warning"
                        confirm="This clears the PIN and password. The employee must set new credentials on next login. Continue?"
                        groups="base.group_system"/>
                </header>
                <sheet>
                    <!-- Employee + Badge -->
                    <group string="Identity">
                        <group>
                            <field name="employee_id"/>
                            <field name="company_id" readonly="1"/>
                            <field name="username"
                                   placeholder="e.g. john.doe"
                                   help="Username for mobile app username+password login. Falls back to work email if not set."/>
                            <field name="badge_id"
                                   placeholder="e.g. EMP-001"
                                   help="Mobile app badge ID for badge+PIN login. Must be unique within the company. Independent from the HR barcode field."/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="last_reset_date" readonly="1"/>
                            <field name="reset_by_id" readonly="1"/>
                        </group>
                    </group>

                    <!-- Set PIN -->
                    <group string="PIN Credential">
                        <group>
                            <field name="pin_is_set" string="PIN Currently Set" readonly="1" widget="boolean"/>
                            <field name="new_pin"
                                   password="True"
                                   placeholder="Min 4 digits — leave blank to keep current"
                                   help="Type a new PIN and save to update. The value is hashed immediately and never stored in plain text."
                                   groups="base.group_system"/>
                        </group>
                    </group>

                    <!-- Set Password -->
                    <group string="Password Credential">
                        <group>
                            <field name="password_is_set" string="Password Currently Set" readonly="1" widget="boolean"/>
                            <field name="new_password"
                                   password="True"
                                   placeholder="Min 6 characters — leave blank to keep current"
                                   help="Type a new password and save to update. The value is hashed immediately and never stored in plain text."
                                   groups="base.group_system"/>
                        </group>
                    </group>

                    <!-- Hashed values (system-only audit) -->
                    <group string="Stored Hashes" groups="base.group_system">
                        <field name="pin_hash" readonly="1"/>
                        <field name="password_hash" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Action window ───────────────────────────────────────────────────── -->
    <record id="action_ess_employee_credential" model="ir.actions.act_window">
        <field name="name">Employee Mobile Credentials</field>
        <field name="res_model">ess.employee.credential</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

</odoo>
