<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List view ───────────────────────────────────────────────────────── -->
    <record id="view_ess_license_list" model="ir.ui.view">
        <field name="name">ess.license.list</field>
        <field name="model">ess.license</field>
        <field name="arch" type="xml">
            <list string="ESS Licenses">
                <field name="name"/>
                <field name="company_id"/>
                <field name="license_key"/>
                <field name="tier"/>
                <field name="expiry_date"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ── Form view ───────────────────────────────────────────────────────── -->
    <record id="view_ess_license_form" model="ir.ui.view">
        <field name="name">ess.license.form</field>
        <field name="model">ess.license</field>
        <field name="arch" type="xml">
            <form string="ESS License">
                <sheet>
                    <group>
                        <group string="License Info">
                            <field name="name"/>
                            <field name="license_key"/>
                            <field name="tier"/>
                            <field name="active"/>
                        </group>
                        <group string="Scope">
                            <field name="company_id"/>
                            <field name="expiry_date"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Action window ───────────────────────────────────────────────────── -->
    <record id="action_ess_license" model="ir.actions.act_window">
        <field name="name">License Keys</field>
        <field name="res_model">ess.license</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
